# SpotlightReady – Mastra Agents Environment Variables
# Copy this file to .env and fill in real values

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: OPEN_AI | ANTHROPIC | GROQ | FEATHERLESS
AI_PROVIDER=OPEN_AI
AI_MODEL=gpt-4o

# If using OpenAI
OPENAI_API_KEY=sk-...

# If using Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# If using Featherless AI (hackathon sponsor platform)
# https://featherless.ai
FEATHERLESS_API_KEY=your_featherless_key
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1

# ── Mastra Server ─────────────────────────────────────────────────────────────
PORT=4111
