# SpotlightReady – Backend Environment Variables
# Copy this to .env and fill in real values — NEVER commit .env

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend URL (for CORS) ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://spotlightready.vercel.app

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Free: https://cloud.mongodb.com → create free M0 cluster → get connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=spotlightready
# Production: MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Options: groq | featherless | openai
# Recommended for development: groq (free, fast, no credit card)
# Get key at: https://console.groq.com → API Keys
LLM_PROVIDER=groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Featherless AI (hackathon sponsor – use for demo/presentation)
# Get key at: https://featherless.ai
FEATHERLESS_API_KEY=

# OpenAI (optional fallback)
OPENAI_API_KEY=
