# ─────────────────────────────────────────
# SpotlightReady – .gitignore
# ─────────────────────────────────────────

# ── Dependencies ──────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Build outputs ─────────────────────────
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# ── Environment variables ─────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ── OS / Editor ───────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ──────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Testing ───────────────────────────────
coverage/
.nyc_output/
cypress/videos/
cypress/screenshots/

# ── pnpm ──────────────────────────────────
pnpm-lock.yaml.bak

# ── Misc ──────────────────────────────────
*.tgz
.cache/
.temp/
uploads/
recordings/         # session recordings (user-generated, not committed)
