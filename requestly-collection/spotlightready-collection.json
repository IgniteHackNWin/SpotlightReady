{
  "info": {
    "name": "SpotlightReady – AI Performance Engine",
    "description": "Complete API collection for SpotlightReady's real-time performance simulation engine. Covers the full session lifecycle: create → live metrics → AI report generation → email delivery. Pre-request scripts auto-generate realistic metrics timelines. Post-response scripts validate all 7 report sections and score integrity.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "BASE_URL", "value": "http://localhost:4000/api", "type": "string" },
    { "key": "SESSION_ID", "value": "", "type": "string" },
    { "key": "USER_ID", "value": "demo-user-yuvraj", "type": "string" }
  ],
  "item": [
    {
      "name": "1. Health & System Checks",
      "description": "Verify backend health, MongoDB Atlas connectivity, and Groq LLM (third-party AI API) reachability. Response timing is asserted to catch latency regressions.",
      "item": [
        {
          "name": "GET  Health Check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/health" },
            "description": "Confirms the Express server is running and MongoDB Atlas is connected. Used during development to verify deployment before testing any business logic."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Backend is alive', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('DB connection is healthy', () => {",
                  "  pm.expect(res.db).to.equal('connected');",
                  "});",
                  "",
                  "pm.test('Response under 500ms', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(500);",
                  "});",
                  "",
                  "console.log('Health:', JSON.stringify(res, null, 2));"
                ]
              }
            }
          ]
        },
        {
          "name": "GET  Groq LLM Connectivity Test",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/health/test-groq" },
            "description": "Validates that the Groq API key is active and the llama-3.3-70b-versatile model is reachable. Response time is asserted — LLM cold starts over 5s indicate quota or network issues."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Groq API is reachable', () => {",
                  "  pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test('LLM response time under 8s', () => {",
                  "  pm.expect(pm.response.responseTime).to.be.below(8000);",
                  "});",
                  "",
                  "console.log('Groq latency:', pm.response.responseTime + 'ms');",
                  "console.log('Response:', JSON.stringify(res, null, 2));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Session Lifecycle",
      "description": "The core AI pipeline. Create a session (triggers AI question generation), submit it with transcript + metrics timeline (triggers LLM evaluation), then poll for the completed report.",
      "item": [
        {
          "name": "POST  Create Interview Session",
          "request": {
            "method": "POST",
            "url": { "raw": "{{BASE_URL}}/sessions" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{USER_ID}}\",\n  \"config\": {\n    \"mode\": \"interview\",\n    \"role\": \"Software Development Engineer\",\n    \"experienceLevel\": \"mid\",\n    \"companyType\": \"faang\",\n    \"difficulty\": \"intermediate\",\n    \"timeLimitMinutes\": 2,\n    \"totalQuestions\": 5\n  }\n}"
            },
            "description": "Creates a new interview session. The backend immediately calls Groq LLM to pre-generate role-specific questions using the SMART model (llama-3.3-70b-versatile). The returned sessionId is auto-saved to the environment variable SESSION_ID, chaining directly into all subsequent requests."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Auto-generate a unique userId so each test run is isolated",
                  "const userId = 'demo-' + Date.now();",
                  "pm.collectionVariables.set('USER_ID', userId);",
                  "console.log('Testing with userId:', userId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Session created successfully', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Session ID is returned', () => {",
                  "  pm.expect(res.data.sessionId).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "pm.test('AI pre-generated questions', () => {",
                  "  pm.expect(res.data.questions).to.be.an('array');",
                  "  pm.expect(res.data.questions.length).to.be.above(0);",
                  "});",
                  "",
                  "// Chain SESSION_ID into all next requests automatically",
                  "pm.collectionVariables.set('SESSION_ID', res.data.sessionId);",
                  "",
                  "console.log('Session ID saved:', res.data.sessionId);",
                  "console.log('Questions generated:', res.data.questions.length);",
                  "res.data.questions?.forEach((q, i) => console.log(`Q${i+1}:`, q));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST  Create Speech Session",
          "request": {
            "method": "POST",
            "url": { "raw": "{{BASE_URL}}/sessions" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{USER_ID}}\",\n  \"config\": {\n    \"mode\": \"speech\",\n    \"topic\": \"The impact of artificial intelligence on modern software development\",\n    \"audienceSize\": \"medium\",\n    \"durationMinutes\": 5,\n    \"formality\": \"formal\",\n    \"teleprompterEnabled\": false\n  }\n}"
            },
            "description": "Creates a speech rehearsal session. Different config schema from interview mode — demonstrates SpotlightReady's dual-mode architecture."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Speech session created', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Session ID returned', () => {",
                  "  pm.expect(res.data.sessionId).to.be.a('string');",
                  "});",
                  "",
                  "console.log('Speech session:', res.data.sessionId);"
                ]
              }
            }
          ]
        },
        {
          "name": "GET  Fetch Session",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/sessions/{{SESSION_ID}}" },
            "description": "Fetches a session by ID. Verifies session was persisted to MongoDB Atlas correctly."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Session found in DB', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Session ID matches', () => {",
                  "  pm.expect(res.data.sessionId).to.equal(pm.collectionVariables.get('SESSION_ID'));",
                  "});",
                  "",
                  "console.log('Session config:', JSON.stringify(res.data?.config, null, 2));"
                ]
              }
            }
          ]
        },
        {
          "name": "POST  Submit Session — Full AI Pipeline Trigger",
          "request": {
            "method": "POST",
            "url": { "raw": "{{BASE_URL}}/sessions/{{SESSION_ID}}/submit" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{SESSION_ID}}\",\n  \"sessionData\": {\n    \"config\": {\n      \"mode\": \"interview\",\n      \"role\": \"Software Development Engineer\",\n      \"experienceLevel\": \"mid\",\n      \"companyType\": \"faang\",\n      \"difficulty\": \"intermediate\",\n      \"timeLimitMinutes\": 2,\n      \"totalQuestions\": 5\n    },\n    \"startedAt\": \"2026-03-08T10:00:00.000Z\",\n    \"endedAt\": \"2026-03-08T10:05:00.000Z\",\n    \"durationSeconds\": 300,\n    \"transcript\": [\n      {\"text\": \"I have worked extensively with distributed systems and microservices architecture using Java and Spring Boot.\", \"startMs\": 1000, \"endMs\": 5000, \"confidence\": 0.95},\n      {\"text\": \"For FAANG interviews I focus heavily on time complexity and space complexity optimisation using dynamic programming and graph algorithms.\", \"startMs\": 6000, \"endMs\": 11000, \"confidence\": 0.93},\n      {\"text\": \"I use the STAR method to structure behavioral answers, providing specific context, tasks, actions I took, and measurable results.\", \"startMs\": 12000, \"endMs\": 17000, \"confidence\": 0.94},\n      {\"text\": \"My experience with system design includes designing scalable APIs with load balancing, caching strategies using Redis, and database sharding.\", \"startMs\": 18000, \"endMs\": 24000, \"confidence\": 0.91}\n    ],\n    \"metricsTimeline\": {{metricsTimeline}},\n    \"recordingUrl\": null\n  }\n}"
            },
            "description": "The most complex endpoint — submits the completed session to trigger the full AI pipeline: (1) transcript evaluation via SMART LLM (llama-3.3-70b-versatile), (2) feedback generation via FAST LLM (llama-3.1-8b-instant), (3) deterministic scoring engine for WPM, filler rate, eye contact, confidence. Pre-request script auto-generates a realistic 6-snapshot metrics timeline so the scoring engine has real data."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Auto-generate a realistic 6-snapshot metrics timeline",
                  "// This simulates what the frontend captures every 5s during a live session",
                  "// Without this, the scoring engine would receive empty data",
                  "",
                  "const eyeStatuses = ['maintaining','maintaining','looking-away','maintaining','maintaining','maintaining'];",
                  "const wpmProgression = [0, 95, 130, 142, 138, 145]; // ramps up as speaker warms up",
                  "",
                  "const timeline = Array.from({ length: 6 }, (_, i) => ({",
                  "  timestampMs: i * 5000,",
                  "  elapsedSeconds: i * 5,",
                  "  currentWPM: wpmProgression[i],",
                  "  paceStatus: wpmProgression[i] >= 120 && wpmProgression[i] <= 160 ? 'ideal' : wpmProgression[i] < 120 ? 'slow' : 'fast',",
                  "  fillerWordCount: i < 2 ? 2 : Math.max(0, 4 - i), // fewer fillers as session progresses",
                  "  fillerWordBreakdown: { 'um': 1, 'like': i < 2 ? 1 : 0 },",
                  "  repetitions: [],",
                  "  eyeContactScore: 60 + Math.floor(Math.random() * 35),",
                  "  eyeContactStatus: eyeStatuses[i],",
                  "  confidenceScore: Math.round((wpmProgression[i] / 80) * (100 - (i < 2 ? 2 : Math.max(0, 4 - i)) * 3)),",
                  "}));",
                  "",
                  "pm.collectionVariables.set('metricsTimeline', JSON.stringify(timeline));",
                  "",
                  "console.log('Generated metrics timeline:');",
                  "timeline.forEach((snap, i) => {",
                  "  console.log(`  Snapshot ${i+1} — WPM: ${snap.currentWPM}, Eye: ${snap.eyeContactScore}%, Confidence: ${snap.confidenceScore}`);",
                  "});"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('AI pipeline triggered successfully', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});",
                  "",
                  "pm.test('Status is processing or ready', () => {",
                  "  pm.expect(['processing', 'ready']).to.include(res.data?.status);",
                  "});",
                  "",
                  "console.log('Pipeline status:', res.data?.status);",
                  "console.log('Now poll GET /reports/' + pm.collectionVariables.get('SESSION_ID') + ' for results');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3. Reports & Delivery",
      "description": "Poll for the AI-generated 7-section performance report, validate its full schema and score integrity, fetch history, and trigger email delivery.",
      "item": [
        {
          "name": "GET  Poll for AI Report — Full Schema Validation",
          "request": {
            "method": "GET",
            "url": { "raw": "{{BASE_URL}}/reports/{{SESSION_ID}}" },
            "description": "The crown jewel of the collection. Polls for the AI-generated report and runs 10 automated tests: all 7 report sections must be present, total score must be 0-100, score breakdown must sum exactly to total, tier must be one of 5 valid values, and improvement plan must contain actionable drills. This is what 'Endpoint Validation: Verify schemas and status codes' looks like in practice."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "if (!res.success || !res.data) {",
                  "  console.log('Report still generating — retry in 10 seconds...');",
                  "  pm.test('Report available', () => pm.expect(res.success).to.be.true);",
                  "  return;",
                  "}",
                  "",
                  "const report = res.data;",
                  "",
                  "// ── Section presence (7 sections) ──────────────────",
                  "pm.test('Section 1 — Overall Summary present', () => {",
                  "  pm.expect(report.overallSummary).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Section 2 — Speech Analytics present', () => {",
                  "  pm.expect(report.speechAnalytics).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Section 3 — Visual Presence present', () => {",
                  "  pm.expect(report.visualPresence).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Section 4 — Content Intelligence present', () => {",
                  "  pm.expect(report.contentIntelligence).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Section 5 — Grammar & Language present', () => {",
                  "  pm.expect(report.grammarLanguage).to.be.an('object');",
                  "});",
                  "",
                  "pm.test('Section 6 — Replay Markers present', () => {",
                  "  pm.expect(report.replayMarkers).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Section 7 — Improvement Plan present', () => {",
                  "  pm.expect(report.improvementPlan).to.be.an('object');",
                  "});",
                  "",
                  "// ── Score integrity ──────────────────────────────────",
                  "pm.test('Total score is valid (0–100)', () => {",
                  "  pm.expect(report.totalScore).to.be.at.least(0);",
                  "  pm.expect(report.totalScore).to.be.at.most(100);",
                  "});",
                  "",
                  "pm.test('Score breakdown sums to total', () => {",
                  "  const b = report.scoreBreakdown;",
                  "  const sum = b.speechDelivery + b.visualPresence + b.contentQuality + b.confidenceFlow;",
                  "  pm.expect(sum).to.equal(report.totalScore);",
                  "});",
                  "",
                  "pm.test('Performance tier is valid', () => {",
                  "  const validTiers = ['Beginner', 'Developing', 'Competent', 'Confident', 'Executive'];",
                  "  pm.expect(validTiers).to.include(report.overallSummary.tier);",
                  "});",
                  "",
                  "pm.test('Improvement drills generated by AI', () => {",
                  "  pm.expect(report.improvementPlan.drills).to.be.an('array');",
                  "  pm.expect(report.improvementPlan.drills.length).to.be.above(0);",
                  "});",
                  "",
                  "// ── Human-readable summary in console ───────────────",
                  "const b = report.scoreBreakdown;",
                  "console.log('');",
                  "console.log('════════ SPOTLIGHTREADY REPORT ════════');",
                  "console.log('  Total Score  :', report.totalScore + '/100');",
                  "console.log('  Tier         :', report.overallSummary.tier);",
                  "console.log('  Speech       :', b.speechDelivery + '/30  | WPM:', report.speechAnalytics.averageWPM);",
                  "console.log('  Visual       :', b.visualPresence + '/20  | Eye Contact:', report.visualPresence.averageEyeContactPercent + '%');",
                  "console.log('  Content      :', b.contentQuality + '/30  ← most important');",
                  "console.log('  Confidence   :', b.confidenceFlow + '/20');",
                  "console.log('  Strengths    :', report.overallSummary.topStrengths.join(' | '));",
                  "console.log('  Improvements :', report.overallSummary.topImprovements.join(' | '));",
                  "console.log('  Drills       :', report.improvementPlan.drills.length, 'generated');",
                  "console.log('════════════════════════════════════════');"
                ]
              }
            }
          ]
        },
        {
          "name": "GET  All Reports for User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{BASE_URL}}/reports?userId={{USER_ID}}",
              "query": [{ "key": "userId", "value": "{{USER_ID}}" }]
            },
            "description": "Fetches the full report history for a user. Tests that pagination is working and results are sorted by date descending."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Reports list returned', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "  pm.expect(res.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Max 20 results returned', () => {",
                  "  pm.expect(res.data.length).to.be.at.most(20);",
                  "});",
                  "",
                  "console.log('Total reports for user:', res.data.length);"
                ]
              }
            }
          ]
        },
        {
          "name": "POST  Email Report to User",
          "request": {
            "method": "POST",
            "url": { "raw": "{{BASE_URL}}/reports/{{SESSION_ID}}/email" },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"yuvraj.r0810@gmail.com\"\n}"
            },
            "description": "Triggers the email delivery pipeline — fetches the stored report, builds a dark-mode HTML email with score card, strengths, improvement areas, and drills, then sends via Gmail SMTP (nodemailer). Tests verify the email was dispatched successfully."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test('Email dispatched', () => {",
                  "  pm.expect(res.success).to.be.true;",
                  "});",
                  "",
                  "console.log('Report emailed. Response:', JSON.stringify(res.data, null, 2));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
